FOOTBALL_API_KEY=your_key_from_football-data.org
ADMIN_TOKEN=choose_a_long_random_string
PORT=3001
VITE_API_URL=http://localhost:3001
NODE_ENV=development

# WC 2026 competition code on football-data.org
# Find it by hitting GET https://api.football-data.org/v4/competitions
# The FIFA World Cup 2026 competition code is WC (or WCQ for qualifiers)
FOOTBALL_COMPETITION_CODE=WC

# --- Solana / Jupiter Predict eligibility ---
# Program ID of the Jupiter Predict program. When set, every wallet submission
# is checked against the Solana RPC for at least one prior tx that touched
# this program. Leave blank to disable the check (dev mode).
JUPITER_PREDICT_PROGRAM=
# Solana RPC URL used for the eligibility check.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: override DB path (default: ./server/data/wc2026.db)
# DB_PATH=./server/data/wc2026.db

# Sync interval in seconds (default: 60)
# SYNC_INTERVAL_SECONDS=60
